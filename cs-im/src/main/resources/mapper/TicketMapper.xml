<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.im.repo.TicketMapper">

    <resultMap id="BaseMap" type="com.example.im.domain.Ticket">
        <id     property="id"             column="id"/>
        <result property="ticketNo"       column="ticket_no"/>
        <result property="customerId"     column="customer_id"/>
        <result property="agentUsername"  column="agent_username"/>
        <result property="sessionId"      column="session_id"/>
        <result property="title"          column="title"/>
        <result property="description"    column="description"/>
        <result property="category"       column="category"/>
        <result property="priority"       column="priority"/>
        <result property="status"         column="status"/>
        <result property="slaDeadline"    column="sla_deadline"/>
        <result property="createdAt"      column="created_at"/>
        <result property="updatedAt"      column="updated_at"/>
        <result property="resolvedAt"     column="resolved_at"/>
        <result property="closedAt"       column="closed_at"/>
    </resultMap>

    <select id="findByTicketNo" resultMap="BaseMap">
        SELECT * FROM ticket WHERE ticket_no = #{ticketNo} AND (deleted = 0 OR deleted IS NULL) LIMIT 1
    </select>

    <select id="findByCustomerIdOrderByIdDesc" resultMap="BaseMap">
        SELECT * FROM ticket WHERE customer_id = #{customerId} AND (deleted = 0 OR deleted IS NULL)
        ORDER BY id DESC
    </select>

    <select id="findByAgentUsernameOrderByIdDesc" resultMap="BaseMap">
        SELECT * FROM ticket WHERE agent_username = #{agentUsername} AND (deleted = 0 OR deleted IS NULL)
        ORDER BY id DESC
    </select>

    <select id="findByStatusOrderByPriorityDesc" resultMap="BaseMap">
        SELECT * FROM ticket WHERE status = #{status} AND (deleted = 0 OR deleted IS NULL)
        ORDER BY FIELD(priority,'URGENT','HIGH','NORMAL','LOW'), id ASC
    </select>

</mapper>