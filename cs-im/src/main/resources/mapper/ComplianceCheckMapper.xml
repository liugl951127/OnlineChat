<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.im.repo.ComplianceCheckMapper">
    <select id="findByOrderNo" resultType="com.example.im.domain.ComplianceCheck">
        SELECT * FROM compliance_check WHERE order_no = #{orderNo} LIMIT 1
    </select>
</mapper>