<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.im.repo.ReplayJobMapper">

    <resultMap id="BaseResultMap" type="com.example.im.domain.ReplayJob">
        <id     property="id"            column="id"/>
        <result property="sessionId"     column="session_id"/>
        <result property="status"        column="status"/>
        <result property="frameCount"    column="frame_count"/>
        <result property="videoUrl"      column="video_url"/>
        <result property="durationMs"    column="duration_ms"/>
        <result property="errorMessage"  column="error_message"/>
        <result property="startedAt"     column="started_at"/>
        <result property="finishedAt"    column="finished_at"/>
        <result property="createdAt"     column="created_at"/>
    </resultMap>

    <select id="findBySession" resultMap="BaseResultMap">
        SELECT id, session_id, status, frame_count, video_url, duration_ms,
               error_message, started_at, finished_at, created_at
        FROM replay_job
        WHERE session_id = #{sessionId}
        ORDER BY id DESC
    </select>

    <select id="findLatestBySession" resultMap="BaseResultMap">
        SELECT id, session_id, status, frame_count, video_url, duration_ms,
               error_message, started_at, finished_at, created_at
        FROM replay_job
        WHERE session_id = #{sessionId}
        ORDER BY id DESC
        LIMIT 1
    </select>

</mapper>