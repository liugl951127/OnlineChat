<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.im.repo.BankCardMapper">

    <resultMap id="BaseMap" type="com.example.im.domain.BankCard">
        <id     property="id"             column="id"/>
        <result property="customerId"     column="customer_id"/>
        <result property="cardNoEnc"      column="card_no_enc"/>
        <result property="cardNoMasked"   column="card_no_masked"/>
        <result property="cardName"       column="card_name"/>
        <result property="bankCode"       column="bank_code"/>
        <result property="bankName"       column="bank_name"/>
        <result property="cardType"       column="card_type"/>
        <result property="mobile"         column="mobile"/>
        <result property="isDefault"      column="is_default"/>
        <result property="verified"       column="verified"/>
        <result property="verifiedAt"     column="verified_at"/>
        <result property="status"         column="status"/>
        <result property="createdAt"      column="created_at"/>
        <result property="updatedAt"      column="updated_at"/>
    </resultMap>

    <select id="findByCustomerIdOrderByIsDefaultDesc" resultMap="BaseMap">
        SELECT * FROM bank_card
        WHERE customer_id = #{customerId} AND (deleted = 0 OR deleted IS NULL)
        ORDER BY is_default DESC, id ASC
    </select>

    <select id="findDefaultByCustomerId" resultMap="BaseMap">
        SELECT * FROM bank_card
        WHERE customer_id = #{customerId} AND is_default = 1
          AND (deleted = 0 OR deleted IS NULL) LIMIT 1
    </select>

    <select id="findByCardNoEnc" resultMap="BaseMap">
        SELECT * FROM bank_card
        WHERE card_no_enc = #{cardNoEnc} AND (deleted = 0 OR deleted IS NULL) LIMIT 1
    </select>

</mapper>