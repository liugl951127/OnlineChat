<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.im.repo.FaqCategoryMapper">

    <resultMap id="BaseMap" type="com.example.im.domain.FaqCategory">
        <id     property="id"          column="id"/>
        <result property="name"        column="name"/>
        <result property="parentId"    column="parent_id"/>
        <result property="sortOrder"   column="sort_order"/>
        <result property="icon"        column="icon"/>
        <result property="createdAt"   column="created_at"/>
    </resultMap>

    <select id="findAllTopLevel" resultMap="BaseMap">
        SELECT * FROM faq_category WHERE (parent_id IS NULL OR parent_id = 0)
          AND (deleted = 0 OR deleted IS NULL)
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="findByParentId" resultMap="BaseMap">
        SELECT * FROM faq_category WHERE parent_id = #{parentId}
          AND (deleted = 0 OR deleted IS NULL)
        ORDER BY sort_order ASC, id ASC
    </select>

</mapper>