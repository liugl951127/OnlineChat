<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.im.repo.ChatSessionMapper">

    <resultMap id="BaseMap" type="com.example.im.domain.ChatSession">
        <id property="id" column="id"/>
        <result property="customerId" column="customer_id"/>
        <result property="agentUsername" column="agent_username"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="queuedAt" column="queued_at"/>
        <result property="acceptedAt" column="accepted_at"/>
        <result property="endedAt" column="ended_at"/>
        <result property="endedBy" column="ended_by"/>
        <result property="lastActiveAt" column="last_active_at"/>
        <result property="lastMessageAt" column="last_message_at"/>
    </resultMap>

    <select id="findActiveByCustomer" resultMap="BaseMap">
        SELECT * FROM chat_session
        WHERE customer_id = #{customerId}
          AND status IN ('ROBOT','QUEUED','IN_SESSION','TRADE_CHECKING')
        ORDER BY id DESC
        LIMIT 1
    </select>

    <select id="findByStatus" resultMap="BaseMap">
        SELECT * FROM chat_session
        WHERE status = #{status}
        ORDER BY queued_at ASC, id ASC
    </select>

    <select id="findByCustomerId" resultMap="BaseMap">
        SELECT * FROM chat_session
        WHERE customer_id = #{customerId}
        ORDER BY id DESC
    </select>

    <select id="findByAgentUsername" resultMap="BaseMap">
        SELECT * FROM chat_session
        WHERE agent_username = #{agentUsername}
        ORDER BY last_active_at DESC
    </select>

</mapper>