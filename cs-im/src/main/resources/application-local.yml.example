# =====================================================
# OnlineChat cs-im 本地开发配置 (v2.3.1)
# =====================================================
# 用法:
#   1. 复制本文件: cp application-local.yml.example application-local.yml
#   2. IDEA Run Config 加: --spring.profiles.active=local
#   3. 修改下方路径为你本机的实际位置
# =====================================================

cs:
  monitor:
    # 本地生成: bash scripts/gen-monitor-keypair.sh (Linux/macOS)
    # 或者在 IDEA 里跑 GenSM2Key main 方法
    enabled: false                                                  # 没生成密钥就先关
    sm2-priv-pem-path: ${user.home}/.cs/cs-monitor.priv.pem          # Linux/macOS
    # sm2-priv-pem-path: C:\Users\你的用户名\.cs\cs-monitor.priv.pem  # Windows
    storage-dir: ${user.home}/cs-data/monitor                       # 存到你 home 目录
    segment-duration-ms: 5000
    retention-days: 30                                              # 本地 30 天够了, 生产 180
  replay:
    storage-dir: ${user.home}/cs-data/replay

spring:
  data:
    redis:
      host: ${REDIS_HOST:127.0.0.1}
      port: ${REDIS_PORT:6379}

# ============ 本地日志友好输出 ============
logging:
  pattern:
    console: "%d{HH:mm:ss.SSS} %-5level [%thread] %logger{20} - %msg%n"
  level:
    root: INFO
    com.example.im: DEBUG
