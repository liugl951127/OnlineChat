/* pages/chat/chat.wxss */
.chat-page { display: flex; flex-direction: column; height: 100vh; background: #f5f7fa; }
.session-bar {
  padding: 16rpx 24rpx;
  background: #f6ffed;
  color: #389e0d;
  font-size: 26rpx;
  display: flex; gap: 8rpx; align-items: center;
}
.session-bar.warning { background: #fff7e6; color: #d46b08; }
.messages {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}
.msg-row { margin-bottom: 24rpx; display: flex; }
.msg-row.mine { justify-content: flex-end; }
.msg-bubble {
  max-width: 70%;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #fff;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}
.msg-row.mine .msg-bubble { background: #1677ff; color: #fff; }
.msg-system { color: #86909c; font-style: italic; }
.msg-time { font-size: 20rpx; color: #c9cdd4; margin-top: 4rpx; text-align: right; }
.input-bar {
  display: flex; gap: 16rpx; padding: 16rpx;
  background: #fff; border-top: 1rpx solid #e5e6eb;
}
.input {
  flex: 1;
  min-height: 60rpx;
  max-height: 200rpx;
  padding: 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 30rpx;
}
.send-btn {
  background: #1677ff; color: #fff;
  font-size: 28rpx; padding: 0 32rpx;
  border-radius: 8rpx;
}