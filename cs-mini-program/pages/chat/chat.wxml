<!-- pages/chat/chat.wxml -->
<view class="chat-page">
  <view class="session-bar" wx:if="{{agentName}}">
    <text class="agent-icon">🎧</text>
    <text class="agent-text">坐席 {{agentName}} 正在服务</text>
  </view>
  <view class="session-bar warning" wx:elif="{{statusTip}}">
    <text class="agent-icon">⏳</text>
    <text class="agent-text">{{statusTip}}</text>
  </view>

  <scroll-view class="messages" scroll-y="true" scroll-into-view="{{lastMsgId}}" scroll-with-animation="true">
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}" class="msg-row {{item.mine ? 'mine' : ''}}">
      <view class="msg-bubble">
        <view wx:if="{{item.fromRole === 'SYSTEM'}}" class="msg-system">⚙ {{item.text}}</view>
        <view wx:else>{{item.text}}</view>
        <view class="msg-time">{{item.timeText}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="input-bar">
    <textarea
      class="input"
      placeholder="输入消息..."
      value="{{inputText}}"
      bindinput="onInput"
      bindconfirm="send"
      auto-height="true"
      maxlength="2000"
    />
    <button class="send-btn" bindtap="send" disabled="{{sending}}">发送</button>
  </view>
</view>